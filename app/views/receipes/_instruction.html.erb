<div class="nested-form-wrapper" data-new-record="<%= instruction_form.object.new_record? %>">
  <h3>
    Instruction <span class="record-counter"></span>
  </h3>

  <%= instruction_form.hidden_field :id %>
  <%= instruction_form.hidden_field :step, value: instruction_form.index %>

  <div>
    <%= instruction_form.label :body, style: "display: block" %>
    <%= instruction_form.text_area :body, rows: 5 %>
  </div>

  <% unless instruction_form.index == 0 %>
    <button type="button" data-action="nested-form#remove">Remove instruction</button>
  <% end %> 

  <%= instruction_form.hidden_field :_destroy %>
</div>